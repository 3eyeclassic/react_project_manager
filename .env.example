# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Demo user (optional - for demo mode login)
# VITE_DEMO_USER_EMAIL=demo@example.com
# VITE_DEMO_USER_PASSWORD=demo-password

# Google Calendar (OAuth). Client ID is used in the frontend for the auth URL.
# Set GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, GOOGLE_REDIRECT_URI in Supabase Edge Function secrets.
# For demo user skip, set DEMO_USER_EMAIL in Edge Function secrets to match VITE_DEMO_USER_EMAIL.
VITE_GOOGLE_CLIENT_ID=
